{
  "manifest_version": 3,
  "name": "ILCS Handover Generator",
  "version": "1.0",
  "description": "Generate handover report from ILCS API",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://servant-be.ilcs.co.id/*",
    "https://*.ilcs.co.id/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ILCS Handover"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png"
  }
}
